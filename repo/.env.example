# RentOps environment configuration template.
# Copy to .env and adjust values for your environment.

# Symfony
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=change_me_in_production

# Database
DATABASE_URL=mysql://rentops:rentops_secret@mysql:3306/rentops?serverVersion=8.0

# JWT
JWT_SECRET=local_jwt_secret_key_change_in_production
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=1209600

# Payment callback signature
PAYMENT_SHARED_SECRET=local_payment_shared_secret

# Backups
BACKUP_ENCRYPTION_KEY=local_backup_encryption_key_32ch
BACKUP_STORAGE_PATH=/var/www/storage/backups
STORAGE_PATH=/var/www/storage

# Frontend
NODE_ENV=development
